<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Latar belakang putih murni -->
    <item>
        <color android:color="#FFFFFF" />
    </item>

    <!--
      Logo sushi diperkecil menjadi 48dp agar tampil minimalis di tengah
      dan benar-benar aman dari pemotongan sistem (sesuai permintaan Anda).
    -->
    <item
        android:width="48dp"
        android:height="48dp"
        android:gravity="center">
        <bitmap
            android:src="@drawable/ic_sushi_logo"
            android:gravity="center" />
    </item>
</layer-list>